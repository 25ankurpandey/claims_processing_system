{
  "name": "claims-processing-system",
  "version": "1.0.0",
  "description": "Insurance Claims Processing System — Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev:backend": "npx tsx watch --tsconfig apps/backend/tsconfig.json apps/backend/src/index.ts",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build:backend": "tsc -p apps/backend/tsconfig.json",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "node dist/apps/backend/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint 'apps/**/*.ts' 'libs/**/*.ts'",
    "typecheck": "tsc --noEmit -p apps/backend/tsconfig.json",
    "seed": "npx tsx --tsconfig apps/backend/tsconfig.json apps/backend/src/seed/run-seed.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "inversify": "^6.0.1",
    "inversify-binding-decorators": "^4.0.0",
    "inversify-express-utils": "^6.4.3",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.0",
    "uuid": "^9.0.1",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
