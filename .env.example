# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4300

# ─── PostgreSQL Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=claims_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_LOGGING=true

# ─── JWT Authentication ──────────────────────────────────────
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=24h

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
