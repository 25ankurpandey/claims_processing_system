{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/backend",
    "rootDir": "../../",
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "./src/**/*.ts",
    "../../libs/shared/enums/**/*.ts",
    "../../libs/shared/interfaces/**/*.ts",
    "../../libs/shared/types/**/*.ts",
    "../../libs/shared/constants/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts", "dist"]
}
